{
  "project": "Vault Secure Web3 Storage",
  "vaultVersion": "0.1",
  "developer": "aman",

  "network": {
    "name": "aptos-testnet",
    "description": "Experimental Aptos testnet environment"
  },

  "storage": {
    "mode": "hash-verification",
    "type": "simulation",
    "file": "vault.json"
  },

  "features": {
    "hashStorage": true,
    "recordVerification": true,
    "testMode": true,
    "logging": true
  },

  "security": {
    "hashAlgorithm": "sha256",
    "duplicateProtection": true
  }
}
{
  "network": "aptos-testnet",
  "version": "1.1",
  "lastUpdated": "2026-03-21"
}
